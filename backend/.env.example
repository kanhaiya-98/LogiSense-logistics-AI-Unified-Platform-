# ── Required ──────────────────────────────────────────────
# Get yours at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional ──────────────────────────────────────────────
# Default: gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash

# Server port (Railway/Render set this automatically)
PORT=8000
